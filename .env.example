# AutoMap environment template
# v0.0 uses mock data by default. Database checks are opt-in.

AUTOMAP_ENV=development
AUTOMAP_LAYER_CATALOG_PATH=data/layer_catalog.example.json

DATABASE_URL=postgresql+psycopg2://automap_user:your_password@localhost:5432/automaps
AUTOMAP_DB_SCHEMA=automap
POSTGRES_ADMIN_URL=postgresql+psycopg2://postgres:your_admin_password@localhost:5432/postgres
