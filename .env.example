# AutoMap environment template
# Local settings only. Do not commit real secrets in .env.

AUTOMAP_ENV=development
AUTOMAP_LAYER_CATALOG_PATH=data/layer_catalog.example.json
AUTOMAP_FRONTEND_URL=http://localhost:3010
AUTOMAP_API_BASE_URL=http://127.0.0.1:8010
NEXT_PUBLIC_AUTOMAP_API_BASE_URL=http://127.0.0.1:8010
PORT=3010
BACKEND_PORT=8010
AUTOMAP_BACKEND_PORT=8010

# Local development:
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_LOCAL_POSTGRES_PASSWORD@localhost:5433/automap
#
# Supabase production backend placeholder:
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_SUPABASE_DB_PASSWORD@db.mjfbpmatxvjczikqbuva.supabase.co:5432/postgres
AUTOMAP_DB_SCHEMA=automap
POSTGRES_ADMIN_URL=postgresql+psycopg2://postgres:YOUR_LOCAL_POSTGRES_PASSWORD@localhost:5433/postgres
ALLOWED_ORIGINS=http://localhost:3010,http://127.0.0.1:3010,https://auto-map-cyan.vercel.app
ALLOWED_ORIGIN_REGEX=^https://(?:auto-map-cyan|auto-[a-z0-9-]+-(?:khoi9034|khoi-nguyens-projects-9f6b140b)|auto-map-[a-z0-9-]+-(?:khoi9034|khoi-nguyens-projects-9f6b140b))\.vercel\.app$
FRONTEND_ORIGIN=https://auto-map-cyan.vercel.app

ARCGIS_PORTAL_URL=https://www.arcgis.com
ARCGIS_USERNAME=your_username
ARCGIS_PASSWORD=your_password
ARCGIS_TARGET_FOLDER=AutoMap Drafts
ARCGIS_PUBLISH_ENV=dev
AUTOMAP_PUBLISH_DRY_RUN=true
AUTOMAP_ALLOW_REAL_PUBLISH=false

# Optional backend-only AI planner. Keep disabled unless the backend host has a secret key configured.
# Never use NEXT_PUBLIC_ for this key and never expose it to the frontend.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
AUTOMAP_AI_PROVIDER=openai
AUTOMAP_AI_ENABLED=false
AUTOMAP_AI_MODEL=gpt-5.5
AUTOMAP_AI_TIMEOUT_SECONDS=20
AUTOMAP_AI_MAX_RETRIES=1
AUTOMAP_AI_PLANNER_MODE=structured_map_plan
AUTOMAP_AI_FALLBACK_TO_DETERMINISTIC=true
